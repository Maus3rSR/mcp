# Dependencies (will be re-installed in Docker)
**/node_modules

# Build artifacts (will be rebuilt in Docker)
**/dist

# Turbo cache
**/.turbo

# Environment files (secrets must be injected at runtime via Dokploy)
**/.env
**/.env.*
!**/.env.example

# Git
.git
.gitignore

# Docker files themselves
**/Dockerfile
**/.dockerignore

# Editors / OS
.vscode
.idea
**/.DS_Store
