HIBOUTIK_BASE_URL=https://votrecompte.hiboutik.com/api
HIBOUTIK_USER=votre_utilisateur_api
HIBOUTIK_API_KEY=votre_cle_api_ici

# Transport mode: "stdio" (default, pour Claude Desktop / Cursor) ou "http" (pour déploiement distant)
TRANSPORT=stdio

# Port HTTP (uniquement utilisé si TRANSPORT=http)
PORT=3000

# Token Bearer pour protéger le endpoint /mcp (recommandé en mode HTTP)
# Générer avec : openssl rand -hex 32
MCP_AUTH_TOKEN=
